FF8DA1# vim:ft=kitty

## name:     Catppuccin Kitty Mocha
## author:   Catppuccin Org
## license:  MIT
## upstream: https://github.com/catppuccin/kitty/blob/main/themes/mocha.conf
## blurb:    Soothing pastel theme for the high-spirited!



# The basic colors
foreground              #CE53E0
background              #341539
selection_foreground    #FF8DA1
selection_background    #341539
background_opacity 0.95
background_blur 15
# Cursor colors
cursor                  #FF8DA1
cursor_text_color       #FF8DA1

# Scrollbar colors
scrollbar_handle_color  #9399b2
scrollbar_track_color   #45475a

# URL color when hovering with mouse
url_color               #FF1DCE

# Kitty window border colors
active_border_color     #b4befe
inactive_border_color   #6c7086
bell_border_color       #f9e2af

# OS Window titlebar colors
wayland_titlebar_color system
macos_titlebar_color system

# Tab bar colors
active_tab_foreground   #FF1DCE
active_tab_background   #8B008B
inactive_tab_foreground #8B008B
inactive_tab_background #8B008B
tab_bar_background      #11111b

# Colors for marks (marked text in the terminal)
mark1_foreground #FF8DA1
mark1_background #b4befe
mark2_foreground #1e1e2e
mark2_background #cba6f7
mark3_foreground #1e1e2e
mark3_background #74c7ec

# The 16 terminal colors

# black
color0 #45475a
color8 #585b70

# red
color1 #f38ba8
color9 #f38ba8

# green
color2  #FF1DCE
color10 #FF1DCE

# yellow
color3  #f9e2af
color11 #f9e2af

# blue
color4  #be00c2
color12 #a000a3

# magenta
color5  #f5c2e7
color13 #f5c2e7

# pink
color6  #FF8DA1
color14 #f497a8

# white
color7  #bac2de
color15 #a6adc8
